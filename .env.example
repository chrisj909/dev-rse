# RSE Environment Configuration — copy to .env and fill in values
# Alembic commands are shell commands run from backend/, not SQL you paste into the Supabase SQL editor.

# Application
# Local development: development
# Vercel/hosted deployments: production
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
# Local Docker example:
# DATABASE_URL=postgresql+asyncpg://rse_user:rse_password@localhost:5432/rse_db
# DATABASE_SYNC_URL=postgresql://rse_user:rse_password@localhost:5432/rse_db
# Hosted/Vercel example (Supabase):
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_SYNC_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres  # used by Alembic

# Supabase (backend)
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_ANON_KEY=sb_publishable_...

# Supabase (frontend — set these in frontend/.env.local and Vercel env vars)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Frontend
# Local/Codespaces example:
# API_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# Vercel same-origin deployments can usually leave these unset.
# If you need explicit URLs, point them at your deployed app domain.
API_URL=
NEXT_PUBLIC_API_URL=

# Scoring
SCORING_VERSION=v2
SCORE_THRESHOLD=25               # Webhook fires when score >= this value

# Webhooks
WEBHOOK_URL=
WEBHOOK_SECRET=
WEBHOOK_SCORE_THRESHOLD=25

# Cron (protect the /cron/run-signals endpoint)
CRON_SECRET=
