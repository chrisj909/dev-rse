# RSE Environment Configuration — copy to .env and fill in values

# Application
APP_ENV=development           # development | production
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://rse_user:rse_password@db:5432/rse_db
DATABASE_SYNC_URL=postgresql://rse_user:rse_password@db:5432/rse_db  # used by Alembic

# Scoring
SCORING_VERSION=v1
SCORE_THRESHOLD=25            # Webhook fires when score >= this value

# Webhooks (Sprint 5)
WEBHOOK_URL=
WEBHOOK_SECRET=
