{
        "version": 2,
        "builds": [
                    {
                                    "src": "api/index.py",
                                    "use": "@vercel/python",
                                    "config": {
                                                        "runtime": "python3.11",
                                                        "includeFiles": ["backend/**", "requirements.txt"]
                                    }
                    },
                    {
                                    "src": "frontend/package.json",
                                    "use": "@vercel/next"
                    }
        ],
        "routes": [
                    {
                                    "src": "/api/(.*)",
                                    "dest": "api/index.py"
                    },
                    {
                                    "src": "/(.*)",
                                    "dest": "frontend/$1"
                    }
        ]
}
